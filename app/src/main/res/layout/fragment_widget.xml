<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="WidgetFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="위젯 실습"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Chronometer
            android:id="@+id/chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="20sp" />

        <Button
            android:id="@+id/btnStartChrono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="크로노미터 시작"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnStopChrono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="크로노미터 정지"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="선택 날짜: 없음"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvSelectedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="선택 시간: 없음"
            android:layout_marginTop="8dp" />

        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:showWeekNumber="false" />

        <TimePicker
            android:id="@+id/timePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:timePickerMode="spinner" />

        <Button
            android:id="@+id/btnWidgetDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="안내 다이얼로그"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>