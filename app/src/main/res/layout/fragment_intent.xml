<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.intent.IntentFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="인텐트 실습"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="SecondActivity로 보낼 메시지"
            android:inputType="text" />

        <Button
            android:id="@+id/btnOpenSecond"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="명시적 인텐트로 화면 열기"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnOpenWeb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="암시적 인텐트: 웹 열기"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnDial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="암시적 인텐트: 전화"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이미지 선택"
            android:layout_marginTop="8dp" />

        <ImageView
            android:id="@+id/ivPickedImage"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="반환 결과 없음"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>